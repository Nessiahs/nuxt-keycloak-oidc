{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node", "nuxt", "@types/node"],
    "declaration": true,
    "paths": {
      "#app": ["./node_modules/nuxt/dist/app"]
    }
  },
  "include": [
    "types",
    "src",
    "test"
  ],
  "exclude": ["dist", "node_modules", "playground"]
}
